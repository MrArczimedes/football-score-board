<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>


<BorderPane prefHeight="700.0" prefWidth="900.0" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="com.sport.radar.football.fx.controllers.MainController">

    <center>
        <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Label text="Live Scoreboard" style="-fx-font-weight: bold; -fx-font-size: 16px;" maxWidth="Infinity">
                    <VBox.margin>
                        <Insets left="5.0" top="5.0" />
                    </VBox.margin>
                </Label>
                <TableView fx:id="scoreboard" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="leftGoalButtons" prefWidth="120.0" text="Home team score buttons" />
                        <TableColumn fx:id="homeTeamName" prefWidth="120.0" text="Home Team" />
                        <TableColumn fx:id="homeTeamScore" prefWidth="120.0" text="Score Home Team" />
                        <TableColumn fx:id="awayTeamName" prefWidth="100.0" text="Away Team" />
                        <TableColumn fx:id="awayTeamScore" prefWidth="80.0" text="Score Away Team" />
                        <TableColumn fx:id="rightGoalButtons" prefWidth="120.0" text="Away team score buttons" />
                        <TableColumn fx:id="finishMatchAndWalkOverButtons" prefWidth="100.0" text="Finish button" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER">
                    <children>
                        <Button mnemonicParsing="false" onAction="#openNewMatchView" text="Add match" />
                    </children>
                    <padding>
                        <Insets bottom="5.0" top="5.0" />
                    </padding>
                </HBox>

                <Label text="Match Summary (Sorted by Total Goals)" style="-fx-font-weight: bold; -fx-font-size: 16px;" maxWidth="Infinity">
                    <VBox.margin>
                        <Insets left="5.0" top="15.0" />
                    </VBox.margin>
                </Label>
                <TableView fx:id="summaryBoard" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="summaryHomeTeamName" prefWidth="120.0" text="Home Team" />
                        <TableColumn fx:id="summaryHomeTeamScore" prefWidth="120.0" text="Score Home Team" />
                        <TableColumn fx:id="summaryAwayTeamName" prefWidth="100.0" text="Away Team" />
                        <TableColumn fx:id="summaryAwayTeamScore" prefWidth="80.0" text="Score Away Team" />
                    </columns>
                </TableView>

            </children>
        </VBox>
    </center>

</BorderPane>