<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER_LEFT" spacing="10.0" prefWidth="300.0" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="com.sport.radar.football.fx.controllers.AddMatchController">
    <children>
        <Label text="Add new match">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </Label>

        <Label text="Home Team name:" />
        <TextField fx:id="homeTeamField" />

        <Label text="Away team name:" />
        <TextField fx:id="awayTeamField" />

        <Button mnemonicParsing="false" onAction="#saveMatch" text="Add match" maxWidth="Infinity">
            <VBox.margin>
                <Insets top="15.0" />
            </VBox.margin>
        </Button>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
